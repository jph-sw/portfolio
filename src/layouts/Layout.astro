---
import "../styles/global.css"
interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta name="description" content="Jan Philipps" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <script
            data-goatcounter="https://jph.goatcounter.com/count"
            async
            src="//gc.zgo.at/count.js" is:inline></script>
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body class="p-2">
        <slot />
    </body>
</html>
<style is:global>
    html {
        font-family: "Noto Mono", monospace;
    }
</style>
